# Copy to .env on the NAS (Docker Compose) or .env.local for local dev.
#   cp .env.example .env

# --- Docker / Synology (network_mode: host) ---
# App listens on PORT on the NAS IP. Unset → 3000 (docker-compose + Dockerfile default).
# Uncomment if 3000 is already in use on the NAS:
# PORT=3010

# Container user (default root on Synology — matches reference/removedoubles).
# CONTAINER_UID=0
# CONTAINER_GID=0

# --- Local dev only ---
# Hostname for Next.js allowedDevOrigins when using a Cloudflare tunnel (see CLOUDFLARED.md).
# NEXT_DEV_TUNNEL_HOST=dev.example.com

# Set to 1 to disable Serwist service worker during local dev.
# DISABLE_SW=1

# Verbose npm ci logs during Docker build (optional).
# NPM_CI_LOGLEVEL=verbose
